# Server Configuration
PORT=5000

# AI Provider Selection: 'openai' or 'gemini'
AI_PROVIDER=openai

# OpenAI Configuration (Required if AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: OpenAI Model (defaults to gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Gemini Configuration (Required if AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Gemini Model (defaults to gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash
